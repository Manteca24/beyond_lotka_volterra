predator_prey/*.gif
predator_prey/*.mp4
predator_prey/*.avi

# OJO: web/assets/simulacion_definitiva.gif SÍ se sube (necesario para la web)
# Si quieres excluirlo explícitamente: añade una línea  !web/assets/*.gif

# ─── Documentos privados / borradores ────────────────────────────────
# El PDF de la memoria NO se sube al repo público
predator_prey/*.pdf
*.pdf

# ─── Archivos generados que se pueden regenerar ──────────────────────
